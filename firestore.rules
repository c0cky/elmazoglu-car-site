rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['user', 'admin'] &&
             data.createdAt == request.time;
    }

    function isValidCar(data) {
      return data.keys().hasAll(['make', 'model', 'year', 'price', 'ownerUid', 'status', 'createdAt']) &&
             data.make is string && data.make.size() <= 50 &&
             data.model is string && data.model.size() <= 50 &&
             data.year is number && data.year >= 1900 && data.year <= 2100 &&
             data.price is number && data.price >= 0 &&
             data.ownerUid == request.auth.uid &&
             data.status in ['available', 'sold', 'reserved'] &&
             data.createdAt == request.time;
    }

    // Collections

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via Google Console
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL']) &&
        request.resource.data.uid == resource.data.uid;
    }

    match /public_users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /cars/{carId} {
      allow read: if true;
      allow list: if true; // Public marketplace
      allow create: if isEmailVerified() && isValidCar(request.resource.data);
      allow update: if (isOwner(resource.data.ownerUid) || isAdmin()) && (
        // Standard user update
        (isOwner(resource.data.ownerUid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['price', 'status', 'description', 'photos', 'features'])) ||
        // Admin update
        isAdmin()
      );
      allow delete: if isOwner(resource.data.ownerUid) || isAdmin();
    }

    match /swap_offers/{offerId} {
      allow read: if isSignedIn() && (isOwner(resource.data.senderUid) || isOwner(resource.data.receiverUid) || isAdmin());
      allow create: if isSignedIn() && request.resource.data.senderUid == request.auth.uid;
      allow update: if isSignedIn() && (
        (isOwner(resource.data.receiverUid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
        isAdmin()
      );
    }

    match /chats/{chatId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.participants);
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      allow create: if isSignedIn() && (request.auth.uid == request.resource.data.senderUid);
    }
  }
}
