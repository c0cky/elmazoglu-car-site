{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Car": {
      "title": "Car",
      "description": "A car listing for sale or swap",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "make": { "type": "string" },
        "model": { "type": "string" },
        "year": { "type": "number" },
        "price": { "type": "number" },
        "mileage": { "type": "number" },
        "fuelType": { "type": "string" },
        "transmission": { "type": "string" },
        "photos": { "type": "array", "items": { "type": "string" } },
        "ownerUid": { "type": "string" },
        "description": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["available", "sold", "reserved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["make", "model", "year", "price", "ownerUid", "status"]
    },
    "SwapOffer": {
      "title": "SwapOffer",
      "description": "An offer to swap a car for another",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fromCarId": { "type": "string" },
        "toCarId": { "type": "string" },
        "senderUid": { "type": "string" },
        "receiverUid": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromCarId", "toCarId", "senderUid", "receiverUid", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderUid": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderUid", "text"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User sensitive data"
    },
    "/public_users/{userId}": {
      "schema": "User",
      "description": "Public user profile information"
    },
    "/cars/{carId}": {
      "schema": "Car",
      "description": "Car listings"
    },
    "/swap_offers/{offerId}": {
      "schema": "SwapOffer",
      "description": "Swap negotiation records"
    },
    "/chats/{chatId}": {
      "schema": "object",
      "description": "Chat metadata"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Conversation history"
    }
  }
}
